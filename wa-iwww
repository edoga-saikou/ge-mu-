<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>ゾンビ回避サバイバル</title>
<style>
body{
    margin:0;
    overflow:hidden;
    background:#111;
    color:white;
    font-family:sans-serif;
    text-align:center;
}
h1{margin-top:10px;}
#info{position:fixed;top:40px;width:100%;}
.player{
    width:30px;
    height:30px;
    background:cyan;
    position:absolute;
    border-radius:50%;
}
.zombie{
    width:30px;
    height:30px;
    background:red;
    position:absolute;
    border-radius:50%;
}
</style>
</head>
<body>

<h1>🧟 ゾンビ回避サバイバル 🧟</h1>
<p id="info">マウスで逃げろ！</p>

<div id="player" class="player"></div>

<script>
const player = document.getElementById("player");
let zombies = [];
let playing = true;
let startTime = Date.now();

player.style.left = window.innerWidth/2 + "px";
player.style.top = window.innerHeight/2 + "px";

document.addEventListener("mousemove", e=>{
    if(!playing) return;
    player.style.left = e.clientX - 15 + "px";
    player.style.top = e.clientY - 15 + "px";
});

function spawnZombie(){
    const z = document.createElement("div");
    z.className="zombie";
    z.style.left = Math.random()*window.innerWidth + "px";
    z.style.top = Math.random()*window.innerHeight + "px";
    document.body.appendChild(z);
    zombies.push(z);
}

function moveZombies(){
    if(!playing) return;

    const px = player.offsetLeft;
    const py = player.offsetTop;

    zombies.forEach(z=>{
        const zx = z.offsetLeft;
        const zy = z.offsetTop;

        const dx = px - zx;
        const dy = py - zy;
        const dist = Math.sqrt(dx*dx + dy*dy);

        z.style.left = zx + dx/dist*1.5 + "px";
        z.style.top = zy + dy/dist*1.5 + "px";

        if(dist < 25){
            endGame();
        }
    });

    requestAnimationFrame(moveZombies);
}

function endGame(){
    playing = false;
    const time = ((Date.now()-startTime)/1000).toFixed(2);
    alert("💀 捕まった！生存時間: "+time+"秒");
    location.reload();
}

setInterval(()=>{
    if(playing) spawnZombie();
},3000);

moveZombies();
</script>

</body>
</html>
