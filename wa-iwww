<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Dodge Game</title>
<style>
body{
    margin:0;
    overflow:hidden;
    background:#111;
}
#player{
    width:40px;
    height:40px;
    background:cyan;
    border-radius:50%;
    position:absolute;
    bottom:20px;
}
.ball{
    width:30px;
    height:30px;
    background:red;
    border-radius:50%;
    position:absolute;
    top:0;
}
#score{
    position:fixed;
    top:10px;
    left:10px;
    color:white;
    font-family:sans-serif;
}
</style>
</head>
<body>

<div id="score">時間: 0</div>
<div id="player"></div>

<script>
const player = document.getElementById("player");
const scoreText = document.getElementById("score");
let playing = true;
let time = 0;

player.style.left = window.innerWidth/2 + "px";

document.addEventListener("mousemove", e=>{
    player.style.left = e.clientX - 20 + "px";
});

function spawnBall(){
    if(!playing) return;

    const ball = document.createElement("div");
    ball.className="ball";
    ball.style.left = Math.random()*window.innerWidth + "px";
    document.body.appendChild(ball);

    let pos = 0;
    const fall = setInterval(()=>{
        if(!playing){
            clearInterval(fall);
            return;
        }

        pos += 5;
        ball.style.top = pos + "px";

        const px = player.offsetLeft;
        const py = player.offsetTop;
        const bx = ball.offsetLeft;
        const by = ball.offsetTop;

        if(
            bx < px+40 &&
            bx+30 > px &&
            by < py+40 &&
            by+30 > py
        ){
            playing = false;
            alert("ゲームオーバー！生存時間: "+time+"秒");
            location.reload();
        }

        if(pos > window.innerHeight){
            clearInterval(fall);
            ball.remove();
        }

    },30);
}

setInterval(()=>{
    if(playing) spawnBall();
},800);

setInterval(()=>{
    if(playing){
        time++;
        scoreText.textContent="時間: "+time;
    }
},1000);

</script>

</body>
</html>
